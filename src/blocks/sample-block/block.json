{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "boilerplate-blocks/sample-block",
	"version": "0.1.0",
	"title": "Boilerplate Blocks",
	"category": "widgets",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {
		"attributes": {
			"preview": true
		}
	},
	"attributes": {
		"content": {
			"type": "string"
		},
		"tag": {
			"type": "string",
			"default": "h2"
		},
		"opacity": {
			"type": "number",
			"selectors": {
				".{{WRAPPER}} .sample-block__content": "opacity: {{VALUE}};"
			}
		},
		"textColor": {
			"type": "string",
			"selectors": {
				".{{WRAPPER}} .sample-block__content": "color: {{VALUE}};"
			}
		},
		"fontSize": {
			"type": "string",
			"selectors": {
				".{{WRAPPER}} .sample-block__content": "font-size: {{VALUE}};"
			}
		},
		"alignment": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}} .sample-block__content": "text-align: {{VALUE}};"
			}
		}
	},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"textdomain": "boilerplate-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}