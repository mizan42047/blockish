{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blockish/container",
	"version": "0.1.0",
	"title": "Container",
	"category": "blockish-framework",
	"icon": "smiley",
	"description": "Example block scaffolded with Create Block tool.",
	"example": {
		"attributes": {
			"preview": true
		}
	},
	"attributes": {
		"isVariationPicked": {
			"type": "boolean",
			"default": false
		},
		"tagName": {
			"type": "object",
			"default": {
				"label": "Div",
				"value": "div"
			}
		},
		"display": {
			"type": "object",
			"default": {
				"Desktop": "flex",
				"Tablet": "flex",
				"Mobile": "flex"
			},
			"selectors": {
				".{{WRAPPER}}": "display: {{VALUE}};"
			}
		},
		"flexWrap": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "flex-wrap: {{VALUE}};"
			}
		},
		"flexDirection": {
			"type": "object",
			"default": {
				"Desktop": {
					"label": "Column",
					"value": "column"
				}
			},
			"selectors": {
				".{{WRAPPER}}": "flex-direction: {{VALUE}};"
			}
		},
		"justifyContent": {
			"type": "object",
			"default": {
				"Desktop": {
					"label": "Center",
					"value": "center"
				},
				"Tablet": {
					"label": "Center",
					"value": "center"
				},
				"Mobile": {
					"label": "Center",
					"value": "center"
				}
			},
			"selectors": {
				".{{WRAPPER}}": "justify-content: {{VALUE}};"
			}
		},
		"alignItems": {
			"type": "object",
			"default": {
				"Desktop": {
					"label": "Center",
					"value": "center"
				},
				"Tablet": {
					"label": "Center",
					"value": "center"
				},
				"Mobile": {
					"label": "Center",
					"value": "center"
				}
			},
			"selectors": {
				".{{WRAPPER}}": "align-items: {{VALUE}};"
			}
		},
		"columnGap": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "column-gap: {{VALUE}};"
			}
		},
		"rowGap": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "row-gap: {{VALUE}};"
			}
		}
	},
	"supports": {
		"html": true,
		"anchor": true
	},
	"textdomain": "blockish",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}