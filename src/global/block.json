{
	"attributes": {
		"blockClass": {
			"type": "string"
		},
		"styles": {
			"type": "string"
		},
		"padding": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "padding: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"margin": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "margin: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"zIndex": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "z-index: {{VALUE}};"
			}	
		},
		"minWidth": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "min-width: {{VALUE}};"
			}
		},
		"maxWidth": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "max-width: {{VALUE}};"
			}
		},
		"widthType": {
			"type": "object"
		},
		"customWidth": {
			"type": "object"
		},
		
		"preview": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js"
}