{
	"attributes": {
		"blockClass": {
			"type": "string"
		},
		"styles": {
			"type": "string"
		},
		"padding": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "padding: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"margin": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "margin: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"preview": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./index.js"
}