{
	"attributes": {
		"blockClass": {
			"type": "string"
		},
		"styles": {
			"type": "string"
		},
		"padding": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "padding: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"margin": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "margin: {{TOP}} {{RIGHT}} {{BOTTOM}} {{LEFT}};"
			}
		},
		"zIndex": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "z-index: {{VALUE}};"
			}	
		},
		"minWidth": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "min-width: {{VALUE}};"
			}
		},
		"maxWidth": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "max-width: {{VALUE}};"
			}
		},
		"widthType": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "width: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "!=",
						"key": "widthType",
						"value": "custom"
					}
				]
			}
		},
		"customWidth": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}": "width: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "==",
						"key": "widthType",
						"value": "custom"
					}
				]
			}
		},
		"position": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "position: {{VALUE}}; width: 100%;"
			}
		},
		"positionTop": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "top: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "not_empty",
						"key": "position",
						"value": ""
					}
				]
			}
		},
		"positionRight": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "right: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "not_empty",
						"key": "position",
						"value": ""
					}
				]
			}
		},
		"positionBottom": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "bottom: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "not_empty",
						"key": "position",
						"value": ""
					}
				]
			}
		},
		"positionLeft": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "left: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "not_empty",
						"key": "position",
						"value": ""
					}
				]
			}
		},
		"alignSelf": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "align-self: {{VALUE}};"
			}
		},
		"flexOrder": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "order: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "!=",
						"key": "flexOrder",
						"value": "custom"
					}
				]
			}
		},
		"flexCustomOrder": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "order: {{VALUE}};"
			},
			"condition": {
				"rules": [
					{
						"condition": "==",
						"key": "flexOrder",
						"value": "custom"
					}
				]
			}
		},
		"flexGrow": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "flex-grow: {{VALUE}};"
			}
		},
		"flexShrink": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "flex-shrink: {{VALUE}};"
			}
		},
		"transform": {
			"type": "object",
			"selectors": {
				".{{WRAPPER}}.wp-block": "transform: rotate({{VALUE}}deg);"
			}
		},
		"preview": {
			"type": "boolean",
			"default": false
		}
	},
	"usesContext": [ "display" ],
	"editorScript": "file:./index.js"
}